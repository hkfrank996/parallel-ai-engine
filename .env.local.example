# Parallel — Environment Variables
# Copy this file to .env.local and fill in values
# If no API key is set, the app runs in Mock Mode (no external API needed)

# Optional: force env provider selection.
# Valid values: openai | anthropic | openrouter | ollama | mock
# If empty, auto-detects: OPENAI_API_KEY > ANTHROPIC_API_KEY > Mock Mode
LLM_PROVIDER=openai

# === OpenAI-compatible API (default) ===
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# To use a custom OpenAI-compatible endpoint (e.g. self-hosted or third-party):
# OPENAI_BASE_URL=https://your-custom-endpoint.example.com/v1
# OPENAI_MODEL=your-model-name

# === Anthropic Claude API ===
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# === OpenRouter (OpenAI-compatible) ===
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# === Ollama (local, no key needed) ===
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# === Timeout ===
LLM_TIMEOUT_MS=90000
